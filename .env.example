# ==============================================
# Infinity Algo by Jeremy - Environment Variables
# ==============================================

# ---------------------------------------------
# Application
# ---------------------------------------------
NEXT_PUBLIC_APP_NAME=Infinity Algo
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=World-Class AI Trading Platform

# ---------------------------------------------
# Supabase Configuration
# ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---------------------------------------------
# AI Integration (z-ai-web-dev-sdk)
# ---------------------------------------------
# The AI assistant uses z-ai-web-dev-sdk for LLM capabilities
# This is handled automatically in the backend

# ---------------------------------------------
# Optional: Analytics & Monitoring
# ---------------------------------------------
NEXT_PUBLIC_GA_ID=your_google_analytics_id
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# ---------------------------------------------
# Optional: Payment Processing (Stripe)
# ---------------------------------------------
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ---------------------------------------------
# Optional: Email Service (Resend/SendGrid)
# ---------------------------------------------
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@infinityalgo.com

# ---------------------------------------------
# Optional: Social Login
# ---------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ---------------------------------------------
# Optional: Market Data APIs
# ---------------------------------------------
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key
TWELVE_DATA_API_KEY=your_twelve_data_key

# ---------------------------------------------
# Development Only
# ---------------------------------------------
NODE_ENV=development
